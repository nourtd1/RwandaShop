# ══════════════════════════════════════════════════════════════════
#  RwandaShop — Variables d'environnement
#  Copier ce fichier : cp .env.local.example .env.local
#  NE JAMAIS commiter .env.local (il est dans .gitignore)
# ══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Source : https://app.supabase.com → Project Settings → API

# URL publique du projet (préfixe NEXT_PUBLIC_ = exposée au navigateur)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé anonyme publique (safe côté client — RLS protège les données)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhubnhubnhueG54biIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MDAwMDAwMDB9.EXAMPLE

# Clé service-role (accès total — NE PAS exposer côté client !)
# Utilisée uniquement dans createAdminClient() côté serveur
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhubnhubnhueG54biIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MTkwMDAwMDAwMH0.EXAMPLE

# JWT secret (pour vérification côté serveur si besoin)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ── Application ───────────────────────────────────────────────────

# URL de base (sans slash final)
# Développement : http://localhost:3000
# Production    : https://rwandashop.rw
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nom de l'app (affiché dans les emails Supabase Auth)
NEXT_PUBLIC_APP_NAME=RwandaShop

# ── SEO / Analytics ───────────────────────────────────────────────

# Google Search Console (balise <meta name="google-site-verification">)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 (optionnel)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Storage ───────────────────────────────────────────────────────

# Bucket Supabase Storage pour les images produits
NEXT_PUBLIC_STORAGE_BUCKET_PRODUCTS=products

# Bucket pour les avatars utilisateurs
NEXT_PUBLIC_STORAGE_BUCKET_AVATARS=avatars

# ── Shipping (paramètres métier) ──────────────────────────────────

# Seuil de livraison gratuite en RWF
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=20000

# Frais de livraison standard en RWF
NEXT_PUBLIC_SHIPPING_FEE=2000

# ── Auth callbacks ────────────────────────────────────────────────
# Configurer aussi dans Supabase Dashboard → Authentication → URL Configuration

# URL de redirection après connexion OAuth
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ── Développement ─────────────────────────────────────────────────

# Active les logs Supabase détaillés (true/false)
NEXT_PUBLIC_SUPABASE_DEBUG=false
